{
  "name": "@qavajs/tx",
  "version": "0.0.12",
  "description": "@qavajs/tx — testing framework via Hammerhead proxy",
  "license": "MIT",
  "author": "Oleksandr Halichenko",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "types/tx.d.ts",
  "bin": {
    "tx": "dist/index.js"
  },
  "files": [
    "dist",
    "types",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "testing",
    "browser",
    "test-runner",
    "hammerhead",
    "e2e",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qavajs/tx.git"
  },
  "bugs": {
    "url": "https://github.com/qavajs/tx/issues"
  },
  "scripts": {
    "build": "node build.mjs",
    "build:watch": "node build.mjs --watch",
    "prepublishOnly": "node build.mjs",
    "start": "node dist/index.js --config test/tx.config.js",
    "dev": "node build.mjs && node dist/index.js --config test/tx.config.js",
    "test": "node build.mjs && node dist/index.js --config test/tx.config.js --test",
    "test:parallel": "node build.mjs && node dist/index.js --config test/tx.config.js --test --workers 4",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit --project test/tsconfig.json",
    "lint": "eslint --fix src",
    "test:unit": "node --require ts-node/register --test test/unit/glob.test.ts test/unit/testRegistrer.test.ts test/unit/runner.test.ts test/unit/locator.test.ts test/unit/executor.test.ts test/unit/route.test.ts"
  },
  "dependencies": {
    "esbuild": "^0.28.0",
    "modern-screenshot": "^4.7.0",
    "picomatch": "^3.0.2",
    "source-map-js": "^1.2.1",
    "testcafe-hammerhead": "^31.7.8",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/picomatch": "^4.0.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "chai": "^6.2.2",
    "eslint": "^10.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
