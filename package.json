{
  "name": "tx-flow",
  "version": "0.0.1",
  "description": "tx-flow — testing framework via Hammerhead proxy",
  "license": "MIT",
  "author": "",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "types/tx.d.ts",
  "bin": {
    "tx": "dist/index.js"
  },
  "files": [
    "dist",
    "types",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "testing",
    "browser",
    "test-runner",
    "cypress",
    "hammerhead",
    "proxy",
    "e2e",
    "automation"
  ],
  "scripts": {
    "build": "node build.mjs",
    "build:watch": "node build.mjs --watch",
    "prepublishOnly": "node build.mjs",
    "start": "node dist/index.js --config test/tx.config.js",
    "dev": "node build.mjs && node dist/index.js --config test/tx.config.js",
    "test": "node build.mjs && node dist/index.js --config test/tx.config.js --test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "testcafe-hammerhead": "^31.7.8"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}