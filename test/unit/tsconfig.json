{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": false,
    "noEmit": true
  },
  "include": [
    "./**/*.ts",
    "../../src/**/*.ts"
  ],
  "exclude": [
    "../../src/browser/**",
    "../../src/core/controller.ts",
    "../../src/panel/**"
  ]
}
